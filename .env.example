# Database Configuration
DATABASE_URL=sqlite:///./storage_app.db
# For PostgreSQL use: postgresql://user:password@localhost/storage_db

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Entra ID Authentication (Optional)
ENABLE_ENTRA_AUTH=false
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_AUTHORITY=https://login.microsoftonline.com/your-azure-tenant-id

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]