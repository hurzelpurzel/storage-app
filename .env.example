# Database Configuration
DATABASE_URL=sqlite:///./storage_app.db
# For PostgreSQL use: postgresql://user:password@localhost/storage_db

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Entra ID Authentication (Optional)
# When false, DEV_USER is auto-logged in without any redirect
ENABLE_ENTRA_AUTH=false
DEV_USER=dev-user
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_AUTHORITY=https://login.microsoftonline.com/your-azure-tenant-id
# Must match the redirect URI registered in your Azure app registration
REDIRECT_URI=http://localhost:3000/

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
NETAPP_ENV_1=DEV/TEST,http://1.2.3.4/api,admin,mypassword1,<svm-uuid>
NETAPP_ENV_2=UAT/PROD,http://5.6.7.8/api,admin,mypassword2,<svm-uuid>
NETAPP_ENV_3=INFRA,http://9.10.11.12/api,admin,mypassword3,<svm-uuid>
NETAPP_VERIFY_SSL=false   # optional, for self-signed certs
TRACE_MODE=false          # Enable logging of raw NetApp API requests/responses